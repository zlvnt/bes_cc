# Salin file ini jadi .env lalu isi nilainya:  cp .env.example .env
# JANGAN commit .env (sudah masuk .gitignore).

# Indikator instance (lokal=local, di AWS instance #1 -> 1, instance #2 -> 2)
INSTANCE_ID=local

# Flask session secret — WAJIB ganti dengan string acak panjang di produksi.
# Generate cepat: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti-dengan-string-acak

# Kredensial PostgreSQL
DB_NAME=tubes
DB_USER=tubes
DB_PASSWORD=ganti-password-ini

# Khusus instance app di AWS: arahkan ke PRIVATE IP instance DB.
# Di lokal (docker-compose.yml) ini di-set otomatis ke "db".
# DB_HOST=10.0.0.x
